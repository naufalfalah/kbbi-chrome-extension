{
  "manifest_version": 3,
  "name": "KBBI - Kamus Besar Bahasa Indonesia",
  "version": "1.0.0",
  "description": "Cari definisi kata bahasa Indonesia langsung dari KBBI (kbbi.web.id)",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Cari di KBBI",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://kbbi.web.id/*"
  ]
}
